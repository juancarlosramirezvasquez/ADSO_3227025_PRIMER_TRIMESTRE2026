{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNE6m7z7t+wAg9CAX40Sn+9"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"KrwmqSH-VsUZ"},"outputs":[],"source":["from dataclasses import dataclass, field\n","from typing import List\n","\n","@dataclass\n","class Catalogo:\n","    _nombre        : str\n","    _categoria     : str\n","    _año_creacion  : int\n","    _responsable   : str\n","    _total_items   : int\n","    _descripcion   : str\n","\n","    # ---- GETTERS ----\n","    @property\n","    def nombre(self) -> str:\n","        return self._nombre\n","\n","    @property\n","    def categoria(self) -> str:\n","        return self._categoria\n","\n","    @property\n","    def año_creacion(self) -> int:\n","        return self._año_creacion\n","\n","    @property\n","    def responsable(self) -> str:\n","        return self._responsable\n","\n","    @property\n","    def total_items(self) -> int:\n","        return self._total_items\n","\n","    @property\n","    def descripcion(self) -> str:\n","        return self._descripcion\n","\n","    # ---- SETTERS ----\n","    @nombre.setter\n","    def nombre(self, nuevo_nombre: str) -> None:\n","        if isinstance(nuevo_nombre, str) and nuevo_nombre.strip():\n","            self._nombre = nuevo_nombre\n","        else:\n","            raise ValueError(\"El nombre debe ser un texto válido y no vacío.\")\n","\n","    @categoria.setter\n","    def categoria(self, nueva_categoria: str) -> None:\n","        categorias_validas = [\"Literatura\", \"Ciencia\", \"Historia\", \"Arte\", \"Tecnología\", \"Otro\"]\n","        if nueva_categoria in categorias_validas:\n","            self._categoria = nueva_categoria\n","        else:\n","            raise ValueError(f\"Categoría inválida. Opciones: {categorias_validas}\")\n","\n","    @año_creacion.setter\n","    def año_creacion(self, nuevo_año: int) -> None:\n","        if isinstance(nuevo_año, int) and 1900 <= nuevo_año <= 2100:\n","            self._año_creacion = nuevo_año\n","        else:\n","            raise ValueError(\"El año debe ser un entero entre 1900 y 2100.\")\n","\n","    @responsable.setter\n","    def responsable(self, nuevo_responsable: str) -> None:\n","        if isinstance(nuevo_responsable, str) and nuevo_responsable.strip():\n","            self._responsable = nuevo_responsable\n","        else:\n","            raise ValueError(\"El responsable debe ser un texto válido y no vacío.\")\n","\n","    @total_items.setter\n","    def total_items(self, nuevo_total: int) -> None:\n","        if isinstance(nuevo_total, int) and nuevo_total >= 0:\n","            self._total_items = nuevo_total\n","        else:\n","            raise ValueError(\"El total de ítems debe ser un número entero positivo.\")\n","\n","    @descripcion.setter\n","    def descripcion(self, nueva_descripcion: str) -> None:\n","        if isinstance(nueva_descripcion, str) and nueva_descripcion.strip():\n","            self._descripcion = nueva_descripcion\n","        else:\n","            raise ValueError(\"La descripción debe ser un texto válido y no vacío.\")\n","\n","    def __repr__(self) -> str:\n","        return (\n","            f\"Catalogo(\\n\"\n","            f\"  nombre       = '{self._nombre}',\\n\"\n","            f\"  categoria    = '{self._categoria}',\\n\"\n","            f\"  año_creacion = {self._año_creacion},\\n\"\n","            f\"  responsable  = '{self._responsable}',\\n\"\n","            f\"  total_items  = {self._total_items},\\n\"\n","            f\"  descripcion  = '{self._descripcion}'\\n\"\n","            f\")\"\n","        )\n","\n","\n","# ---- Programa principal ----\n","def main():\n","    print(\"==== Programa Principal ====\")\n","\n","    catalogo1 = Catalogo(\n","        _nombre       = \"Catálogo General 2024\",\n","        _categoria    = \"Literatura\",\n","        _año_creacion = 2024,\n","        _responsable  = \"Ana Gómez\",\n","        _total_items  = 350,\n","        _descripcion  = \"Catálogo principal de libros de literatura universal.\"\n","    )\n","\n","    print(\"==== Información del Catálogo ====\")\n","    print(catalogo1)\n","\n","    # Actualizar atributos con los setters\n","    catalogo1.nombre       = \"Catálogo Actualizado 2025\"\n","    catalogo1.total_items  = 420\n","    catalogo1.responsable  = \"Luis Martínez\"\n","\n","    print(\"\\n*** Datos actualizados ***\")\n","    print(catalogo1)\n","\n","if __name__ == \"__main__\":\n","    main()"]}]}