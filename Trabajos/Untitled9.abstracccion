{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMVo7WXFHwOSBOCdcISTZsu"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":8,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ENCGITPsHjMU","executionInfo":{"status":"ok","timestamp":1773345854299,"user_tz":300,"elapsed":487188,"user":{"displayName":"Jesus Manuel Arrieta Suárez","userId":"16604041113604320493"}},"outputId":"8262436f-0c3c-4d20-ad9d-ba215885d15b"},"outputs":[{"output_type":"stream","name":"stdout","text":["ingrese el radio del circulo:23\n","Area:1661.91\n"]}],"source":["from abc import ABC,abstractmethod\n","#CREAREMOS LA CLASE ABSTRACTA\n","class Figura(ABC):\n","      @abstractmethod\n","\n","\n","\n","\n","      def calcular_area(self):#este metodo es obligatorio colocarlos en todas las subclases\n","        pass\n","#ahora crearemos las clases hijas de figura\n","class Circulo(Figura):\n","   def __init__(self,radio):\n","      self.radio = radio\n","   def calcular_area(self):\n","        return ((self.radio**2)*3.1416)\n","class Cuadrado(Figura):\n","  pass\n","class Rectangulo(Figura):\n","  pass\n","class Cilindro(Figura):\n","  pass\n","  #vamos a ejecutar\n","def mostrar_area(Figura:Figura):\n","     print(f\"Area:{Figura.calcular_area():.2f}\")\n","def main():\n","    radio1 = float(input(\"ingrese el radio del circulo:\"))\n","    circulo1 = Circulo(radio1)\n","    mostrar_area(circulo1)\n","if __name__==\"__main__\":\n","    main()\n","\n"]},{"cell_type":"code","source":["from abc import ABC,abstractmethod\n","#CREAMOS LA CLASE ABSTRACTA\n","class Empleado(ABC):\n","    def __init__(self,nombre: str)->None:\n","        self._nombre = None #queda el nombre como privado\n","        self.nombre = nombre #aqui llamamas al setter automaticamente\n","    #creamos el GETTER\n","    @property\n","    def nombre(self)->str:\n","        #tenfra acceso seguro al nombre del empleado\n","        return self._nombre\n","    @nombre.setter\n","    def nombre(self,valor:str)->None:#SETTE Rprofecional con validacion basica\n","        #validamos que sea cadena\n","        if isinstance(valor,str) and valor.strip():\n","            self._nombre =valor.strip()\n","        else:\n","            raise ValueError(\"El nombre debe ser de tipo texto.\")\n","    @abstractmethod\n","    def trabajar(self)->None:\n","        #Este metodo es obligatorio en todas las clases por tener @abstractmethod\n","        pass\n","#creamos las clases hija\n","class Gerente(Empleado):\n","    def trabajar (self)->None:\n","        print(f\"{self.nombre}Esta administrando toda la empresa.\")\n","\n","\n","class Desarollador(Empleado):\n","    def trabajar (self)->None:\n","        print(f\"{self.nombre}Esta aescribiendo pagina en PYTHON.\")\n","\n","#EJECUCION DIDACTICA\n","def main():\n","    #creamos los objetos\n","    gerente1 =Gerente(\"kate\")\n","    desarollador1 = Desarollador (\"Cristian valero\")\n","    print(\"********==POLIMORFIRMO CON GETTER Y SETTER==********\")\n","if __name__==\"__main__\":\n","   main()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IOzaxGS5nvds","executionInfo":{"status":"ok","timestamp":1773348982623,"user_tz":300,"elapsed":18,"user":{"displayName":"Jesus Manuel Arrieta Suárez","userId":"16604041113604320493"}},"outputId":"2e8dd229-0c2f-410c-d843-2977f468d8e4"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["********==POLIMORFIRMO CON GETTER Y SETTER==********\n"]}]},{"cell_type":"code","source":["from abc import ABC,abstractmethod\n","class GenerarReporte(ABC):\n","     @abstractmethod\n","     def generar_reporte(self) -> None:\n","          pass\n","\n","class SistemaPago(ABC):\n","     def __init__(self,monto:float)->None:\n","          self.monto = monto #aributos comun sin privar\n","     @abstractmethod\n","     def procesar_pago(self)->None:\n","          #metodo obligatorio definido en la clase abstracta\n","          pass\n","class PagoBancario(SistemaPago,GenerarReporte):\n","\n","     def generar_reporte(self):\n","          print(\"REPORTE:pago realizado mediante sistema bancario\")\n","     def procesar_pago(self):\n","         print(f\"procesando la transferencia bancaria ${self.monto:,.2f}\")\n","class PagoCriptoMonedas(SistemaPago):\n","     def procesar_pago(self)->None:\n","          print(f\"precesando pago CRIPTO MONEDAS, por ${self.monto:,.2f}\")\n","def ejecutar_pago(pago:SistemaPago)->None:\n","    pago.procesar_pago()\n","def main():\n","     print(\"*******==SISTEMA DE PAGO ON INTERFASES ABSTRACTAS==*******\")\n","     pago1 = PagoBancario(30000)\n","     pago2 = PagoCriptoMonedas(50000)\n","     ejecutar_pago(pago1)\n","     pago1.generar_reporte()\n","     print(\"\\nAhora con CRIPTOS\")\n","     ejecutar_pago(pago2)\n","\n","if __name__ == \"__main__\":\n","   main()\n"],"metadata":{"id":"UlEklWBLMVts"},"execution_count":null,"outputs":[]}]}